<form>
    <field>
        <id>subscription.enabled</id>
        <label>启用</label>
        <type>checkbox</type>
        <help>为该订阅启用自动更新（cron）。</help>
        <style>selectpicker</style>
        <grid_view>
            <column>
                <type>command</type>
                <commands>toggle</commands>
                <width>6em</width>
            </column>
        </grid_view>
    </field>
    <field>
        <id>subscription.name</id>
        <label>名称</label>
        <type>text</type>
        <help>订阅名（同时作为配置档名，自动加上 sub- 前缀）。允许的字符：字母、数字、下划线、短横线。</help>
        <grid_view>
            <column>
                <type>string</type>
                <visible>true</visible>
            </column>
        </grid_view>
    </field>
    <field>
        <id>subscription.url</id>
        <label>URL</label>
        <type>text</type>
        <help>Clash / Mihomo YAML 订阅链接。</help>
        <grid_view>
            <column>
                <type>string</type>
                <visible>true</visible>
            </column>
        </grid_view>
    </field>
    <field>
        <id>subscription.user_agent</id>
        <label>User-Agent</label>
        <type>text</type>
        <help>部分提供方根据 User-Agent 区分内容。</help>
        <grid_view>
            <column>
                <type>string</type>
                <visible>false</visible>
            </column>
        </grid_view>
    </field>
    <field>
        <id>subscription.interval</id>
        <label>自动更新间隔（小时）</label>
        <type>text</type>
        <help>0 表示禁用自动更新。建议：6。</help>
        <grid_view>
            <column>
                <type>string</type>
                <visible>true</visible>
            </column>
        </grid_view>
    </field>
    <field>
        <id>subscription.include_keyword</id>
        <label>包含关键词</label>
        <type>text</type>
        <help>逗号分隔。代理节点名必须至少包含其中之一才会保留。</help>
        <grid_view>
            <column>
                <type>string</type>
                <visible>false</visible>
            </column>
        </grid_view>
    </field>
    <field>
        <id>subscription.exclude_keyword</id>
        <label>排除关键词</label>
        <type>text</type>
        <help>逗号分隔。命中任意关键词的代理节点会被丢弃。</help>
        <grid_view>
            <column>
                <type>string</type>
                <visible>false</visible>
            </column>
        </grid_view>
    </field>
    <field>
        <id>subscription.last_update</id>
        <label>上次更新</label>
        <type>text</type>
        <help>只读。由 sub.sh 写入。</help>
        <grid_view>
            <column>
                <type>string</type>
                <visible>true</visible>
            </column>
        </grid_view>
    </field>
    <field>
        <id>subscription.last_status</id>
        <label>上次状态</label>
        <type>text</type>
        <help>只读。idle / updating / done / failed。</help>
        <grid_view>
            <column>
                <type>string</type>
                <visible>true</visible>
            </column>
        </grid_view>
    </field>
</form>
