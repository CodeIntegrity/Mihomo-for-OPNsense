# =========================================================================
# Forms XML — Settings tab field labels
# =========================================================================

# --- general.xml -----------------------------------------------------------
msgid "HTTP Port"
msgstr "HTTP 端口"

msgid "HTTP proxy port (0 disables). Default: 7890."
msgstr "HTTP 代理端口（0 表示禁用）。默认值：7890。"

msgid "SOCKS Port"
msgstr "SOCKS 端口"

msgid "SOCKS5 proxy port (0 disables). Default: 7891."
msgstr "SOCKS5 代理端口（0 表示禁用）。默认值：7891。"

msgid "Mixed Port"
msgstr "混合端口"

msgid "HTTP + SOCKS mixed port (0 disables)."
msgstr "HTTP + SOCKS 混合端口（0 表示禁用）。"

msgid "Allow LAN"
msgstr "允许局域网"

msgid "Accept connections from LAN clients."
msgstr "接受来自局域网客户端的连接。"

msgid "Bind Address"
msgstr "绑定地址"

msgid "Bind address for HTTP/SOCKS listeners. Use * for all interfaces."
msgstr "HTTP/SOCKS 监听绑定地址。* 表示所有接口。"

msgid "Mode"
msgstr "模式"

msgid "Proxy routing mode (rule = via rules, global = all via selected proxy, direct = no proxy)."
msgstr "代理路由模式（rule = 按规则、global = 全局代理、direct = 直连）。"

msgid "Log Level"
msgstr "日志级别"

msgid "Mihomo log verbosity."
msgstr "Mihomo 日志详细程度。"

msgid "IPv6"
msgstr "IPv6"

msgid "Enable IPv6 traffic handling."
msgstr "启用 IPv6 流量处理。"

msgid "TCP Concurrent"
msgstr "TCP 并发"

msgid "Race multiple IPs concurrently to reduce TCP connect latency."
msgstr "并发竞速多个 IP 以降低 TCP 连接延迟。"

msgid "Find Process Mode"
msgstr "进程匹配模式"

msgid "Process matching for PROCESS-NAME rules. Note: strict may not work on FreeBSD."
msgstr "PROCESS-NAME 规则使用的进程匹配模式。注意：strict 在 FreeBSD 上可能无效。"

msgid "Global Client Fingerprint"
msgstr "全局客户端指纹"

msgid "uTLS fingerprint applied to outgoing TLS handshakes."
msgstr "应用于出站 TLS 握手的 uTLS 指纹。"

msgid "Unified Delay"
msgstr "统一延迟"

msgid "Subtract TCP handshake delay so HTTP and HTTPS proxies show comparable latencies."
msgstr "扣除 TCP 握手延迟，使 HTTP 与 HTTPS 代理的延迟具备可比性。"

msgid "Outbound Interface"
msgstr "出站接口"

msgid "Bind outbound traffic to a specific interface (leave empty for auto)."
msgstr "将出站流量绑定到指定接口（留空表示自动选择）。"

# --- controller.xml --------------------------------------------------------
msgid "External Controller"
msgstr "外部控制器"

msgid "RESTful API listen address. Default: 0.0.0.0:9090."
msgstr "RESTful API 监听地址。默认值：0.0.0.0:9090。"

msgid "API Secret"
msgstr "API 密钥"

msgid ""
"Authentication secret for the RESTful API. Leave blank to disable auth (NOT "
"recommended for non-localhost binds)."
msgstr "RESTful API 鉴权密钥。留空将禁用鉴权（绑定到非 localhost 时不建议）。"

msgid "External UI Path"
msgstr "外部 UI 目录"

msgid "Directory served as the Mihomo Dashboard UI. Managed by Updates Tab — edit with care."
msgstr "Mihomo Dashboard UI 所在目录。由「更新」选项卡管理，请谨慎修改。"

# --- tun.xml ---------------------------------------------------------------
msgid "Enable TUN"
msgstr "启用 TUN"

msgid "Master switch for transparent proxy. Disabling will stop Mihomo from intercepting traffic."
msgstr "透明代理总开关。关闭后 Mihomo 将不再劫持流量。"

msgid "Stack"
msgstr "协议栈"

msgid "TUN userspace network stack."
msgstr "TUN 用户态网络栈。"

msgid "Device Name"
msgstr "设备名"

msgid "TUN interface name. Must match the firewall interface created by install.sh."
msgstr "TUN 接口名。必须与 install.sh 创建的防火墙接口同名。"

msgid "MTU"
msgstr "MTU"

msgid "TUN interface MTU. Default: 9000."
msgstr "TUN 接口 MTU。默认值：9000。"

msgid "Auto Route"
msgstr "自动路由"

msgid "Automatically configure routes pointing to the TUN device."
msgstr "自动配置指向 TUN 设备的路由。"

msgid "Strict Route"
msgstr "严格路由"

msgid "Strict route enforcement."
msgstr "严格路由强制。"

msgid "Auto Detect Interface"
msgstr "自动检测接口"

msgid "Auto detect the outbound interface for direct connections."
msgstr "为直连连接自动检测出站接口。"

msgid "DNS Hijack"
msgstr "DNS 劫持"

msgid "Comma-separated list of DNS hijack rules. Default: any:53,tcp://any:53."
msgstr "逗号分隔的 DNS 劫持规则。默认值：any:53,tcp://any:53。"

# --- dns.xml ---------------------------------------------------------------
msgid "Enable"
msgstr "启用"

msgid "Enable Mihomo's built-in DNS resolver."
msgstr "启用 Mihomo 内置 DNS 解析。"

msgid "Listen"
msgstr "监听"

msgid "DNS listen address. Default: 0.0.0.0:53 (Unbound is moved to 5355 by install.sh)."
msgstr "DNS 监听地址。默认值：0.0.0.0:53（Unbound 已被 install.sh 改到 5355）。"

msgid "Resolve AAAA records."
msgstr "解析 AAAA 记录。"

msgid "Enhanced Mode"
msgstr "增强模式"

msgid "fake-ip = synthesize answers for sniffer-based routing (recommended); redir-host = redirect; normal = pass through."
msgstr "fake-ip = 为基于嗅探的路由合成应答（推荐）；redir-host = 重定向；normal = 透传。"

msgid "Fake IP Range"
msgstr "Fake IP 范围"

msgid "CIDR used to synthesize fake answers."
msgstr "用于合成虚假应答的 CIDR。"

msgid "Default Nameserver"
msgstr "默认上游"

msgid "Comma-separated. Default: 127.0.0.1:5355 (the relocated Unbound)."
msgstr "逗号分隔。默认值：127.0.0.1:5355（迁移后的 Unbound）。"

msgid "Nameserver"
msgstr "上游 DNS"

msgid "Comma-separated list of upstream resolvers used for general queries."
msgstr "逗号分隔的上游解析器列表，用于常规查询。"

msgid "Fallback"
msgstr "兜底 DNS"

msgid "Comma-separated list of resolvers used as fallback for international domains."
msgstr "用于境外域名兜底的解析器列表（逗号分隔）。"

msgid "Fake IP Filter"
msgstr "Fake IP 排除"

msgid "Comma-separated domain patterns excluded from fake-ip handling."
msgstr "排除在 fake-ip 处理之外的域名模式（逗号分隔）。"

msgid "Use Hosts"
msgstr "使用 Hosts"

msgid "Honor the Hosts table below."
msgstr "应用下方 Hosts 表中的条目。"

msgid "Hosts"
msgstr "Hosts"

msgid "Static host entries (format: domain=ip; one per line). Optional."
msgstr "静态主机条目（格式：domain=ip，每行一个）。可选。"

# --- sniffer.xml -----------------------------------------------------------
msgid "Enable traffic sniffing to recover the destination domain from intercepted connections."
msgstr "启用流量嗅探，以从拦截的连接中还原目标域名。"

msgid "Force DNS Mapping"
msgstr "强制 DNS 映射"

msgid "Force replace destination IP with sniffed domain."
msgstr "强制将目标 IP 替换为嗅探出的域名。"

msgid "Parse Pure IP"
msgstr "解析纯 IP"

msgid "Run sniffer even when the destination has no associated domain."
msgstr "即使目标没有关联域名，也运行嗅探。"

msgid "Override Destination"
msgstr "覆盖目标"

msgid "Use sniffed domain to override the original destination."
msgstr "使用嗅探出的域名覆盖原始目标。"

msgid "Sniff HTTP Ports"
msgstr "嗅探 HTTP 端口"

msgid "Comma-separated ports / ranges to sniff for HTTP traffic."
msgstr "用于嗅探 HTTP 流量的端口或范围（逗号分隔）。"

msgid "Sniff TLS Ports"
msgstr "嗅探 TLS 端口"

msgid "Comma-separated ports / ranges to sniff for TLS SNI."
msgstr "用于嗅探 TLS SNI 的端口或范围（逗号分隔）。"

msgid "Sniff QUIC Ports"
msgstr "嗅探 QUIC 端口"

msgid "Comma-separated ports / ranges to sniff for QUIC SNI."
msgstr "用于嗅探 QUIC SNI 的端口或范围（逗号分隔）。"

msgid "Skip Domains"
msgstr "跳过域名"

msgid "Comma-separated domain patterns excluded from sniffing."
msgstr "排除在嗅探之外的域名模式（逗号分隔）。"

# --- update.xml ------------------------------------------------------------
msgid "GitHub Mirror"
msgstr "GitHub 镜像"

msgid "Optional URL prefix used to accelerate GitHub downloads, e.g. https://ghproxy.com/."
msgstr "用于加速 GitHub 下载的可选 URL 前缀，如 https://ghproxy.com/。"

msgid "GitHub Token"
msgstr "GitHub Token"

msgid "Optional Personal Access Token used to raise GitHub API rate limits to 5000/h."
msgstr "可选 Personal Access Token，用于将 GitHub API 速率限制提升到 5000/h。"

msgid "Auto Update GeoIP"
msgstr "自动更新 GeoIP"

msgid "Automatically update Country.mmdb weekly."
msgstr "每周自动更新 Country.mmdb。"

msgid "Auto Update Dashboard UI"
msgstr "自动更新 Dashboard 界面"

msgid "Automatically update the embedded Dashboard UI monthly."
msgstr "每月自动更新内置 Dashboard 界面。"

msgid "Auto Update Mihomo Core"
msgstr "自动更新 Mihomo 内核"

msgid "Automatically update the Mihomo binary. NOT recommended — kernel updates can break connectivity."
msgstr "自动更新 Mihomo 二进制。**不推荐**——内核更新可能导致连接中断。"

msgid "Health Check URL"
msgstr "健康检查 URL"

msgid "Used by the Dashboard Health Check button."
msgstr "Dashboard「健康检查」按钮使用的 URL。"

msgid "Health Check Timeout (ms)"
msgstr "健康检查超时（毫秒）"

msgid "Per-node timeout for the health check."
msgstr "每个节点的健康检查超时。"

msgid "Backup before Override save"
msgstr "保存覆写前自动备份"

msgid "Auto create a backup snapshot every time Override is saved."
msgstr "每次保存 Override 前自动创建一份备份快照。"

msgid "Backup before Profile activation"
msgstr "切换配置档前自动备份"

msgid "Auto create a backup snapshot every time a Profile is activated."
msgstr "每次激活配置档前自动创建一份备份快照。"

# --- dialogSubscription.xml ------------------------------------------------
msgid "Activate auto-update cron for this subscription."
msgstr "为该订阅启用自动更新（cron）。"

msgid ""
"Subscription name (becomes the profile name, prefixed with sub-). Allowed: "
"letters, digits, underscore, dash."
msgstr "订阅名（同时作为配置档名，自动加上 sub- 前缀）。允许的字符：字母、数字、下划线、短横线。"

msgid "Clash / Mihomo YAML subscription URL."
msgstr "Clash / Mihomo YAML 订阅链接。"

msgid "User-Agent"
msgstr "User-Agent"

msgid "Some providers gate by User-Agent."
msgstr "部分提供方根据 User-Agent 区分内容。"

msgid "Auto-update Interval (hours)"
msgstr "自动更新间隔（小时）"

msgid "0 disables auto-update. Suggested: 6."
msgstr "0 表示禁用自动更新。建议：6。"

msgid "Include Keywords"
msgstr "包含关键词"

msgid "Comma-separated. Proxy node name must contain at least one of these to be kept."
msgstr "逗号分隔。代理节点名必须至少包含其中之一才会保留。"

msgid "Exclude Keywords"
msgstr "排除关键词"

msgid "Comma-separated. Proxy node names matching any of these are dropped."
msgstr "逗号分隔。命中任意关键词的代理节点会被丢弃。"

msgid "Last Status"
msgstr "上次状态"

msgid "Read-only. idle / updating / done / failed."
msgstr "只读。idle / updating / done / failed。"

msgid "Read-only. Populated by sub.sh."
msgstr "只读。由 sub.sh 写入。"

# Subscription status enum
msgid "Idle"
msgstr "空闲"

msgid "Updating"
msgstr "更新中"

msgid "Done"
msgstr "已完成"

msgid "Failed"
msgstr "失败"

# OptionField values for find_process_mode
msgid "strict (may fail on FreeBSD)"
msgstr "strict（在 FreeBSD 上可能无效）"
